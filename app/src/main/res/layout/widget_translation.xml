<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_background"
    android:gravity="center">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🔤 Tradutor Offline"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"/>

        <TextView
            android:id="@+id/txtLanguagePair"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EN → PT"
            android:textSize="10sp"
            android:textColor="#AAFFFFFF"/>
    </LinearLayout>

    <!-- Last Translation Display -->
    <LinearLayout
        android:id="@+id/translationContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginVertical="8dp"
        android:padding="8dp"
        android:background="#22FFFFFF">

        <TextView
            android:id="@+id/txtSourceText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Texto original"
            android:textSize="11sp"
            android:textColor="#AAAAAA"
            android:maxLines="1"
            android:ellipsize="end"
            android:gravity="center"/>

        <TextView
            android:id="@+id/txtLastTranslation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Toque para traduzir"
            android:textSize="15sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end"
            android:gravity="center"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <!-- Quick Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <ImageButton
            android:id="@+id/btnCamera"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_camera"
            android:background="@android:color/transparent"
            android:scaleType="centerInside"
            android:contentDescription="Câmera"/>

        <ImageButton
            android:id="@+id/btnText"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_edit"
            android:background="@android:color/transparent"
            android:scaleType="centerInside"
            android:contentDescription="Texto"
            android:layout_marginStart="8dp"/>

        <ImageButton
            android:id="@+id/btnSwap"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_rotate"
            android:background="@android:color/transparent"
            android:scaleType="centerInside"
            android:contentDescription="Trocar idiomas"
            android:layout_marginStart="8dp"/>

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"/>

        <Button
            android:id="@+id/btnOpen"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="App"
            android:textSize="11sp"
            android:paddingHorizontal="16dp"
            style="@style/Widget.Material3.Button.TonalButton"/>
    </LinearLayout>

</LinearLayout>