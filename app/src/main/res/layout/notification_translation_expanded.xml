<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#1E1E1E">

    <!-- Header -->
    <TextView
        android:id="@+id/txtTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🔤 EN → PT"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"/>

    <!-- Original Text -->
    <TextView
        android:id="@+id/txtSourceLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Original:"
        android:textSize="11sp"
        android:textColor="#888888"/>

    <TextView
        android:id="@+id/txtSource"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Texto original..."
        android:textSize="13sp"
        android:textColor="#CCCCCC"
        android:maxLines="3"
        android:ellipsize="end"/>

    <!-- Translated Text -->
    <TextView
        android:id="@+id/txtResultLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Tradução:"
        android:textSize="11sp"
        android:textColor="#4CAF50"/>

    <TextView
        android:id="@+id/txtResult"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Texto traduzido..."
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:maxLines="4"
        android:ellipsize="end"/>

    <!-- Action Buttons Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btnCopy"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_save"
            android:background="@android:drawable/btn_default"
            android:contentDescription="Copiar"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="Copiar"
            android:textSize="12sp"
            android:textColor="#FFFFFF"/>

        <View
            android:layout_width="16dp"
            android:layout_height="1dp"/>

        <ImageButton
            android:id="@+id/btnSwap"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_rotate"
            android:background="@android:drawable/btn_default"
            android:contentDescription="Trocar"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="Trocar"
            android:textSize="12sp"
            android:textColor="#FFFFFF"/>

        <View
            android:layout_width="16dp"
            android:layout_height="1dp"/>

        <ImageButton
            android:id="@+id/btnOpen"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_view"
            android:background="@android:drawable/btn_default"
            android:contentDescription="Abrir app"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="App"
            android:textSize="12sp"
            android:textColor="#FFFFFF"/>
    </LinearLayout>

</LinearLayout>
