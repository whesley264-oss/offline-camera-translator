   "source": [
    "# 📊 Análise de Qualidade de Tradução\n",
    "\n",
    "Este notebook analisa a qualidade das traduções do **Offline Camera Translator** comparando com um gabarito (ground truth).\n",
    "\n",
    "## Métricas Analisadas:\n",
    "- **Exact Match**: Tradução idêntica ao gabarito\n",
    "- **BLEU Score**: Score de similaridade textual\n",
    "- **Word Error Rate (WER)**: Taxa de erros por palavra\n",
    "- **Character Error Rate (CER)**: Taxa de erros por caractere"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Importar bibliotecas\n",
    "import json\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "from difflib import SequenceMatcher\n",
    "import re\n",
    "\n",
    "# Configurar estilo dos gráficos\n",
    "plt.style.use('seaborn-v0_8-darkgrid')\n",
    "sns.set_palette(\"husl\")\n",
    "\n",
    "%matplotlib inline"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Carregar dataset de teste\n",
    "with open('../datasets/test_dataset.json', 'r', encoding='utf-8') as f:\n",
    "    dataset = json.load(f)\n",
    "\n",
    "print(f\"📁 Dataset: {dataset['dataset_name']}\")\n",
    "print(f\"📝 Total de amostras: {dataset['total_samples']}\")\n",
    "print(f\"🔤 Pares de idiomas: {dataset['language_pairs']}\")\n",
    "print(f\"📂 Categorias: {', '.join(dataset['categories'])}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Criar DataFrame com o dataset\n",
    "df = pd.DataFrame(dataset['samples'])\n",
    "df['pair'] = df['source_lang'] + '→' + df['target_lang']\n",
    "\n",
    "print(\"📋 Distribuição por categoria:\")\n",
    "print(df['category'].value_counts())\n",
    "print(\"\\n📋 Distribuição por par de idiomas:\")\n",
    "print(df['pair'].value_counts())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ==========================================\n",
    "# FUNÇÕES DE AVALIAÇÃO\n",
    "# ==========================================\n",
    "\n",
    "def normalize_text(text):\n",
    "    \"\"\"Normaliza texto para comparação\"\"\"\n",
    "    text = text.lower().strip()\n",
    "    text = re.sub(r'\\s+', ' ', text)\n",
    "    text = re.sub(r'[^\\w\\sàáâãäåæçèéêëìíîïðñòóôõöøùúûüýþÿ\\-]', '', text)\n",
    "    return text\n",
    "\n",
    "def exact_match(predicted, expected):\n",
    "    \"\"\"Verifica se a tradução é exatamente igual\"\"\"\n",
    "    return normalize_text(predicted) == normalize_text(expected)\n",
    "\n",
    "def similarity_ratio(predicted, expected):\n",
    "    \"\"\"Calcula similaridade entre textos (0-1)\"\"\"\n",
    "    return SequenceMatcher(None, \n",
    "                          normalize_text(predicted), \n",
    "                          normalize_text(expected)).ratio()\n",
    "\n",
    "def word_error_rate(predicted, expected):\n",
    "    \"\"\"Calcula WER - Word Error Rate\"\"\"\n",
    "    pred_words = normalize_text(predicted).split()\n",
    "    exp_words = normalize_text(expected).split()\n",
    "    \n",
    "    if len(exp_words) == 0:\n",
    "        return 0.0 if len(pred_words) == 0 else 1.0\n",
    "    \n",
    "    matcher = SequenceMatcher(None, exp_words, pred_words)\n",
    "    matches = sum(tag == 'equal' for tag in matcher.get_opcodes())\n",
    "    \n",
    "    # Calcular distância de edição\n",
    "    distance = len(exp_words) - matches\n",
    "    return distance / len(exp_words)\n",
    "\n",
    "def character_error_rate(predicted, expected):\n",
    "    \"\"\"Calcula CER - Character Error Rate\"\"\"\n",
    "    pred_chars = list(normalize_text(predicted))\n",
    "    exp_chars = list(normalize_text(expected))\n",
    "    \n",
    "    if len(exp_chars) == 0:\n",
    "        return 0.0 if len(pred_chars) == 0 else 1.0\n",
    "    \n",
    "    matcher = SequenceMatcher(None, exp_chars, pred_chars)\n",
    "    matches = sum(tag == 'equal' for tag in matcher.get_opcodes())\n",
    "    \n",
    "    distance = len(exp_chars) - matches\n",
    "    return distance / len(exp_chars)\n",
    "\n",
    "def calculate_bleu(predicted, expected):\n",
    "    \"\"\"Aproximação simplificada do BLEU score (0-1)\"\"\"\n",
    "    pred_words = normalize_text(predicted).split()\n",
    "    exp_words = normalize_text(expected).split()\n",
    "    \n",
    "    if len(pred_words) == 0 or len(exp_words) == 0:\n",
    "        return 0.0\n",
    "    \n",
    "    # Contar n-gramas em comum\n",
    "    def get_ngrams(words, n):\n",
    "        return set(tuple(words[i:i+n]) for i in range(len(words)-n+1))\n",
    "    \n",
    "    precisions = []\n",
    "    for n in range(1, min(4, len(exp_words) + 1)):\n",
    "        pred_ngrams = get_ngrams(pred_words, n)\n",
    "        exp_ngrams = get_ngrams(exp_words, n)\n",
    "        \n",
    "        if len(pred_ngrams) == 0:\n",
    "            precisions.append(0)\n",
    "        else:\n",
    "            matches = len(pred_ngrams & exp_ngrams)\n",
    "            precisions.append(matches / len(pred_ngrams))\n",
    "    \n",
    "    if sum(precisions) == 0:\n",
    "        return 0.0\n",
    "    \n",
    "    avg_precision = sum(precisions) / len(precisions)\n",
    "    brevity_penalty = min(1.0, len(pred_words) / len(exp_words))\n",
    "    \n",
    "    return avg_precision * brevity_penalty"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ==========================================\n",
    "# SIMULAR RESULTADOS DO APP\n",
    "# (Substitua pelos dados reais quando disponível)\n",
    "# ==========================================\n",
    "\n",
    "# Para demonstração, vamos simular traduções do app\n",
    "# Em produção, você carregaria os dados reais do stats_data.json\n",
    "\n",
    "def simulate_app_translation(source_text):\n",
    "    \"\"\"\n",
    "    SIMULAÇÃO: Em produção, substitua por dados reais\n",
    "    \n",
    "    Aqui simulamos que o app tem ~70% de acerto\n",
    "    com variações para simular erros comuns\n",
    "    \"\"\"\n",
    "    np.random.seed(hash(source_text) % 2**32)\n",
    "    \n",
    "    # Simular taxa de acerto de 70%\n",
    "    if np.random.random() < 0.7:\n",
    "        # Tradução perfeita ou muito próxima\n",
    "        return None  # Usar gabarito\n",
    "    else:\n",
    "        # Simular erros\n",
    "        errors = [\n",
    "            lambda s: s.replace('a', 'e'),  # Troca de vogal\n",
    "            lambda s: s[:-1] if len(s) > 3 else s,  # Falta caractere\n",
    "            lambda s: s + 'x',  # Caractere extra\n",
    "            lambda s: '*** ' + s,  # Prefixo errado\n",
    "        ]\n",
    "        return np.random.choice(errors)(source_text)\n",
    "\n",
    "# Carregar resultados simulados\n",
    "translations = []\n",
    "for sample in dataset['samples']:\n",
    "    simulated = simulate_app_translation(sample['source_text'])\n",
    "    translations.append({\n",
    "        'id': sample['id'],\n",
    "        'source_text': sample['source_text'],\n",
    "        'expected': sample['expected_translation'],\n",
    "        'predicted': simulated if simulated else sample['expected_translation'],\n",
    "        'category': sample['category'],\n",
    "        'pair': sample['source_lang'] + '→' + sample['target_lang']\n",
    "    })\n",
    "\n",
    "results_df = pd.DataFrame(translations)\n",
    "print(f\"📊 Total de traduções simuladas: {len(results_df)}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Calcular métricas para cada tradução\n",
    "results_df['exact_match'] = results_df.apply(\n",
    "    lambda x: exact_match(x['predicted'], x['expected']), axis=1\n",
    ")\n",
    "\n",
    "results_df['similarity'] = results_df.apply(\n",
    "    lambda x: similarity_ratio(x['predicted'], x['expected']), axis=1\n",
    ")\n",
    "\n",
    "results_df['bleu'] = results_df.apply(\n",
    "    lambda x: calculate_bleu(x['predicted'], x['expected']), axis=1\n",
    ")\n",
    "\n",
    "results_df['wer'] = results_df.apply(\n",
    "    lambda x: word_error_rate(x['predicted'], x['expected']), axis=1\n",
    ")\n",
    "\n",
    "results_df['cer'] = results_df.apply(\n",
    "    lambda x: character_error_rate(x['predicted'], x['expected']), axis=1\n",
    ")\n",
    "\n",
    "# Mostrar resultados\n",
    "results_df[['id', 'category', 'exact_match', 'similarity', 'bleu']].head(10)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ==========================================\n",
    "# 📊 RESULTADOS GERAIS\n",
    "# ==========================================\n",
    "\n",
    "print(\"=\" * 60)\n",
    "print(\"📊 RESULTADOS GERAIS DE QUALIDADE\")\n",
    "print(\"=\" * 60)\n",
    "\n",
    "# Métricas principais\n",
    "exact_match_rate = results_df['exact_match'].mean() * 100\n",
    "avg_similarity = results_df['similarity'].mean() * 100\n",
    "avg_bleu = results_df['bleu'].mean() * 100\n",
    "avg_wer = results_df['wer'].mean() * 100\n",
    "avg_cer = results_df['cer'].mean() * 100\n",
    "\n",
    "print(f\"\"\"\n",
    "🎯 TAXA DE ACERTO EXATO (Exact Match)\n",
    "   {exact_match_rate:.1f}%\n",
    "\n",
    "📈 MÉTRICAS DE QUALIDADE\n",
    "   Similaridade Média:      {avg_similarity:.1f}%\n",
    "   BLEU Score Médio:        {avg_bleu:.1f}%\n",
    "\n",
    "⚠️  TAXAS DE ERRO\n",
    "   Word Error Rate (WER):  {avg_wer:.1f}%\n",
    "   Character Error Rate:   {avg_cer:.1f}%\n",
    "\"\"\")\n",
    "\n",
    "# Classificação de qualidade\n",
    "def classify_quality(row):\n",
    "    if row['exact_match']:\n",
    "        return '✅ Perfeito'\n",
    "    elif row['similarity'] >= 0.9:\n",
    "        return '🟢 Excelente'\n",
    "    elif row['similarity'] >= 0.7:\n",
    "        return '🟡 Bom'\n",
    "    elif row['similarity'] >= 0.5:\n",
    "        return '🟠 Regular'\n",
    "    else:\n",
    "        return '🔴 Ruim'\n",
    "\n",
    "results_df['quality'] = results_df.apply(classify_quality, axis=1)\n",
    "\n",
    "print(\"\\n📋 Distribuição de Qualidade:\")\n",
    "print(results_df['quality'].value_counts())"
   ]
  },
  {
   "cell_type": "code",
