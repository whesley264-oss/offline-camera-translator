   "source": [
    "# ==========================================\n",
    "# 📈 VISUALIZAÇÕES\n",
    "# ==========================================\n",
    "\n",
    "fig, axes = plt.subplots(2, 2, figsize=(14, 10))\n",
    "\n",
    "# 1. Distribuição de Qualidade\n",
    "quality_counts = results_df['quality'].value_counts()\n",
    "colors = ['#2ecc71', '#27ae60', '#f1c40f', '#e67e22', '#e74c3c']\n",
    "axes[0, 0].pie(quality_counts.values, labels=quality_counts.index, autopct='%1.1f%%', \n",
    "               colors=colors[:len(quality_counts)], startangle=90)\n",
    "axes[0, 0].set_title('Distribuição de Qualidade', fontsize=14, fontweight='bold')\n",
    "\n",
    "# 2. Score de Similaridade\n",
    "axes[0, 1].hist(results_df['similarity'], bins=20, color='#3498db', edgecolor='white', alpha=0.7)\n",
    "axes[0, 1].axvline(results_df['similarity'].mean(), color='red', linestyle='--', label=f'Média: {results_df[\"similarity\"].mean():.2f}')\n",
    "axes[0, 1].set_xlabel('Similaridade')\n",
    "axes[0, 1].set_ylabel('Frequência')\n",
    "axes[0, 1].set_title('Distribuição de Similaridade', fontsize=14, fontweight='bold')\n",
    "axes[0, 1].legend()\n",
    "\n",
    "# 3. BLEU Score por Categoria\n",
    "category_bleu = results_df.groupby('category')['bleu'].mean().sort_values(ascending=True)\n",
    "category_bleu.plot(kind='barh', ax=axes[1, 0], color='#9b59b6')\n",
    "axes[1, 0].set_xlabel('BLEU Score')\n",
    "axes[1, 0].set_title('BLEU Score por Categoria', fontsize=14, fontweight='bold')\n",
    "\n",
    "# 4. Taxa de Erro (WER vs CER)\n",
    "error_data = results_df[['wer', 'cer', 'category']].melt(id_vars='category', var_name='Metric', value_name='Error Rate')\n",
    "sns.boxplot(data=error_data, x='category', y='Error Rate', hue='Metric', ax=axes[1, 1])\n",
    "axes[1, 1].set_title('Taxas de Erro por Categoria', fontsize=14, fontweight='bold')\n",
    "axes[1, 1].tick_params(axis='x', rotation=45)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('../results/quality_analysis.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "print(\"✅ Gráfico salvo em: results/quality_analysis.png\")"
   ]
  },
